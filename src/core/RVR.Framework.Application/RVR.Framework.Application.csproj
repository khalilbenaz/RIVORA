<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>RVR.Framework.Application</RootNamespace>
    <AssemblyName>RVR.Framework.Application</AssemblyName>
    <LangVersion>13.0</LangVersion>
    <PackageId>RVR.Framework.Application</PackageId>
    <Description>Application layer with CQRS (MediatR), services, validators and DTOs</Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\RVR.Framework.Core\RVR.Framework.Core.csproj" />
    <ProjectReference Include="..\RVR.Framework.Domain\RVR.Framework.Domain.csproj" />
    <ProjectReference Include="..\..\security\RVR.Framework.Security\RVR.Framework.Security.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="MediatR" />
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="FluentValidation.DependencyInjectionExtensions" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
  </ItemGroup>
</Project>
