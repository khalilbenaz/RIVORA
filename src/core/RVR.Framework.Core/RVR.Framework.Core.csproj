<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>RVR.Framework.Core</RootNamespace>
    <AssemblyName>RVR.Framework.Core</AssemblyName>
    <LangVersion>13.0</LangVersion>
    <IsAotCompatible>true</IsAotCompatible>
    <PackageId>RVR.Framework.Core</PackageId>
    <Description>Core abstractions, interfaces and base types for the RIVORA Framework</Description>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
</Project>
