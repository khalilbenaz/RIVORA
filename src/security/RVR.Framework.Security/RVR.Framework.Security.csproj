<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <LangVersion>13.0</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);NU1903;NU1507;CS1591</NoWarn>
    <PackageId>RVR.Framework.Security</PackageId>
    <Description>Security module with JWT, BCrypt, 2FA, rate limiting and audit trail</Description>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\core\RVR.Framework.Core\RVR.Framework.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Authentication -->
    <PackageReference Include="Microsoft.AspNetCore.Authentication.OpenIdConnect" />

    <!-- EF Core for interceptors -->
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />

    <!-- Redis for distributed caching -->
    <PackageReference Include="Microsoft.Extensions.Caching.StackExchangeRedis" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />

    <!-- QR Code generation for 2FA -->
    <PackageReference Include="QRCoder" />

    <!-- TOTP implementation -->
    <PackageReference Include="Otp.NET" />

    <!-- Password hashing -->
    <PackageReference Include="BCrypt.Net-Next" />
  </ItemGroup>

</Project>
