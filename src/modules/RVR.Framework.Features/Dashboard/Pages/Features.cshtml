@page
@model RVR.Framework.Features.Dashboard.Pages.FeaturesModel
@{
    ViewData["Title"] = "Feature Flags Dashboard";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1>@ViewData["Title"]</h1>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="row mb-4">
            <div class="col">
                <div class="alert alert-info alert-dismissible fade show" role="alert">
                    @Model.StatusMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }

    <div class="row mb-4">
        <div class="col">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Create New Feature</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="Create" class="row g-3">
                        <div class="col-md-4">
                            <input type="text" class="form-control" name="featureName" placeholder="Feature Name" required />
                        </div>
                        <div class="col-md-4">
                            <input type="text" class="form-control" name="description" placeholder="Description" />
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-primary">Create Feature</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Features (@Model.Features.Count)</h5>
                </div>
                <div class="card-body">
                    @if (Model.Features.Any())
                    {
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Status</th>
                                    <th>Provider</th>
                                    <th>Description</th>
                                    <th>Last Modified</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var feature in Model.Features)
                                {
                                    <tr>
                                        <td>
                                            <code>@feature.Name</code>
                                        </td>
                                        <td>
                                            @if (feature.Enabled)
                                            {
                                                <span class="badge bg-success">Enabled</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Disabled</span>
                                            }
                                        </td>
                                        <td>@feature.Provider</td>
                                        <td>@(string.IsNullOrEmpty(feature.Description) ? "-" : feature.Description)</td>
                                        <td>@feature.LastModified.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                @if (feature.Enabled)
                                                {
                                                    <form method="post" asp-page-handler="Toggle" class="d-inline">
                                                        <input type="hidden" name="featureName" value="@feature.Name" />
                                                        <input type="hidden" name="enabled" value="false" />
                                                        <button type="submit" class="btn btn-sm btn-warning">Disable</button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <form method="post" asp-page-handler="Toggle" class="d-inline">
                                                        <input type="hidden" name="featureName" value="@feature.Name" />
                                                        <input type="hidden" name="enabled" value="true" />
                                                        <button type="submit" class="btn btn-sm btn-success">Enable</button>
                                                    </form>
                                                }
                                                <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this feature?');">
                                                    <input type="hidden" name="featureName" value="@feature.Name" />
                                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No features found. Create your first feature above.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }
    .table code {
        font-weight: 600;
    }
</style>
