@page "/products"
@using RVR.Framework.Infrastructure.Data
@using RVR.Framework.Domain.Entities.Products
@inject RVRDbContext DbContext

<h1>Produits</h1>

<div class="toolbar">
    <input type="text" placeholder="Rechercher par nom, SKU ou categorie..."
           @bind="_searchTerm" @bind:event="oninput" @bind:after="Search"
           class="search-input" />
    <span class="result-count">@_products.Count resultat(s)</span>
</div>

<table class="data-table">
    <thead>
        <tr>
            <th>Nom</th>
            <th>SKU</th>
            <th>Categorie</th>
            <th>Prix</th>
            <th>Stock</th>
            <th>Actif</th>
            <th>Date creation</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in _products)
        {
            <tr>
                <td>@product.Name</td>
                <td>@product.SKU</td>
                <td>@product.Category</td>
                <td style="text-align:right;">@product.Price.ToString("N2")</td>
                <td style="text-align:right;">
                    <span class="@(product.Stock == 0 ? "badge badge-danger" : product.Stock < 10 ? "badge badge-warning" : "")">
                        @product.Stock
                    </span>
                </td>
                <td>
                    <span class="@(product.IsActive ? "badge badge-success" : "badge badge-danger")">
                        @(product.IsActive ? "Oui" : "Non")
                    </span>
                </td>
                <td>@product.CreatedAt.ToString("yyyy-MM-dd")</td>
            </tr>
        }
    </tbody>
</table>

@if (!_products.Any())
{
    <p class="empty-state">Aucun produit trouve.</p>
}

@code {
    private string _searchTerm = string.Empty;
    private List<Product> _products = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task Search()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        var query = DbContext.Products.AsQueryable();

        if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            var term = _searchTerm.Trim().ToUpper();
            query = query.Where(p =>
                p.Name.ToUpper().Contains(term) ||
                (p.SKU != null && p.SKU.ToUpper().Contains(term)) ||
                (p.Category != null && p.Category.ToUpper().Contains(term)));
        }

        _products = await query
            .OrderBy(p => p.Name)
            .Take(100)
            .ToListAsync();
    }
}
