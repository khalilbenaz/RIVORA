@page "/studio/modules"

<PageTitle>Modules — RVR Studio</PageTitle>

<h1>Gestionnaire de Modules</h1>
<p class="studio-subtitle">Modules RIVORA disponibles. Utilisez <code>rvr add-module</code> ou <code>rvr remove-module</code> pour gerer vos modules.</p>

<div class="toolbar">
    <input type="text" class="search-input" placeholder="Rechercher un module..." @bind="SearchQuery" @bind:event="oninput" />
    <span class="result-count">@FilteredModules.Count() modules</span>
</div>

<div class="modules-grid">
    @foreach (var mod in FilteredModules)
    {
        <div class="module-card">
            <div class="module-header">
                <h4>@mod.Name</h4>
                <span class="badge @(mod.IsCore ? "badge-success" : "badge-method")">
                    @(mod.IsCore ? "Core" : mod.Category)
                </span>
            </div>
            <p class="module-desc">@mod.Description</p>
            <div class="module-footer">
                <code class="module-package">RVR.Framework.@mod.Name</code>
                <div class="module-actions">
                    <button class="btn-sm btn-add" title="rvr add-module @mod.Name">+ Add</button>
                    <button class="btn-sm btn-remove" title="rvr remove-module @mod.Name">- Remove</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string SearchQuery { get; set; } = "";

    private IEnumerable<ModuleInfo> FilteredModules => AllModules
        .Where(m => string.IsNullOrEmpty(SearchQuery) ||
                    m.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                    m.Description.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));

