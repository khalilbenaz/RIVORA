@page "/health"
@using RVR.Framework.Infrastructure.Data
@inject RVRDbContext DbContext
@inject DatabaseStatus DbStatus

<h1>Health Dashboard</h1>

<div class="stats-grid">
    <div class="stat-card @(_dbHealthy ? "" : "stat-card-error")">
        <p class="stat-label">Base de donnees</p>
        <p class="stat-value" style="font-size:1.5rem;">@(_dbHealthy ? "OK" : "Erreur")</p>
        <p class="stat-detail">@_dbResponseTime ms</p>
    </div>
    <div class="stat-card">
        <p class="stat-label">Utilisateurs</p>
        <p class="stat-value">@_userCount</p>
    </div>
    <div class="stat-card">
        <p class="stat-label">Produits actifs</p>
        <p class="stat-value">@_activeProductCount</p>
    </div>
    <div class="stat-card">
        <p class="stat-label">Tenants actifs</p>
        <p class="stat-value">@_activeTenantCount</p>
    </div>
</div>

<h2 style="margin-top:2rem;">Statistiques detaillees</h2>
<table class="data-table">
    <thead>
        <tr>
            <th>Verification</th>
            <th>Statut</th>
            <th>Detail</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>Connexion base de donnees</td>
            <td>
                <span class="@(_dbHealthy ? "badge badge-success" : "badge badge-danger")">
                    @(_dbHealthy ? "Sain" : "Erreur")
                </span>
            </td>
            <td>Temps de reponse : @_dbResponseTime ms</td>
        </tr>
        <tr>
            <td>Utilisateurs totaux</td>
            <td><span class="badge badge-success">@_userCount</span></td>
            <td>dont @_activeUserCount actif(s)</td>
        </tr>
        <tr>
            <td>Produits totaux</td>
            <td><span class="badge badge-success">@_productCount</span></td>
            <td>dont @_activeProductCount actif(s), @_outOfStockCount en rupture de stock</td>
        </tr>
        <tr>
            <td>Tenants totaux</td>
            <td><span class="badge badge-success">@_tenantCount</span></td>
            <td>dont @_activeTenantCount actif(s)</td>
        </tr>
        <tr>
            <td>Audit Logs</td>
            <td><span class="badge badge-success">@_auditLogCount</span></td>
            <td>dont @_errorLogCount en erreur (4xx/5xx)</td>
        </tr>
    </tbody>
</table>

<div style="margin-top:1rem;">
    <button class="btn-refresh" @onclick="Refresh">Rafraichir</button>
</div>

@code {
    private bool _dbHealthy;
    private long _dbResponseTime;
    private int _userCount, _activeUserCount;
    private int _productCount, _activeProductCount, _outOfStockCount;
    private int _tenantCount, _activeTenantCount;
    private int _auditLogCount, _errorLogCount;

    protected override async Task OnInitializedAsync()
    {
        if (!DbStatus.IsConfigured) return;
        try { await LoadHealthData(); } catch { }
    }

    private async Task Refresh()
    {
        await LoadHealthData();
    }

    private async Task LoadHealthData()
    {
        var sw = System.Diagnostics.Stopwatch.StartNew();
        try
        {
            _dbHealthy = await DbContext.Database.CanConnectAsync();
            sw.Stop();
            _dbResponseTime = sw.ElapsedMilliseconds;
        }
        catch
        {
            sw.Stop();
            _dbHealthy = false;
            _dbResponseTime = sw.ElapsedMilliseconds;
            return;
        }

        _userCount = await DbContext.Users.CountAsync();
        _activeUserCount = await DbContext.Users.CountAsync(u => u.IsActive);

        _productCount = await DbContext.Products.CountAsync();
        _activeProductCount = await DbContext.Products.CountAsync(p => p.IsActive);
        _outOfStockCount = await DbContext.Products.CountAsync(p => p.Stock == 0);

        _tenantCount = await DbContext.Tenants.CountAsync();
        _activeTenantCount = await DbContext.Tenants.CountAsync(t => t.IsActive);

        _auditLogCount = await DbContext.AuditLogs.CountAsync();
        _errorLogCount = await DbContext.AuditLogs.CountAsync(a => a.HttpStatusCode != null && a.HttpStatusCode >= 400);
    }
}
