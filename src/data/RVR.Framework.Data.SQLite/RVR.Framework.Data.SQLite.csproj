<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>RVR.Framework.Data.SQLite</RootNamespace>
    <AssemblyName>RVR.Framework.Data.SQLite</AssemblyName>
    <LangVersion>13.0</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>RVR.Framework.Data.SQLite</PackageId>
    <Description>SQLite database provider for RIVORA Framework</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\RVR.Framework.Data.Abstractions\RVR.Framework.Data.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" />
  </ItemGroup>

</Project>
