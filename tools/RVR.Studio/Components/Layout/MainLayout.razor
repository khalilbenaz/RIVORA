@inherits LayoutComponentBase

<div class="page bg-light min-vh-100 d-flex flex-row">
    <!-- Sidebar -->
    <div class="sidebar shadow bg-dark" style="width: 260px; z-index: 1000; position: fixed; height: 100vh; overflow-y: auto;">
        <NavMenu />
    </div>

    <!-- Main Content -->
    <main class="w-100 d-flex flex-column" style="margin-left: 260px;">
        <!-- Top Navbar -->
        <header class="top-row px-4 shadow-sm bg-white d-flex justify-content-between align-items-center" style="height: 60px;">
            <div class="d-flex align-items-center">
                <span class="fs-5 fw-semibold text-dark">RIVORA Framework Studio</span>
            </div>
            <div class="d-flex align-items-center gap-3">
                <div class="position-relative">
                    <span class="bi bi-bell fs-5 text-secondary"></span>
                    <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                        <span class="visually-hidden">New alerts</span>
                    </span>
                </div>
                <div class="dropdown">
                    <button class="btn btn-light dropdown-toggle d-flex align-items-center gap-2 border-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="https://ui-avatars.com/api/?name=Admin+User&background=0D8ABC&color=fff" alt="User" class="rounded-circle" width="30" height="30" />
                        <span>Admin</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow">
                        <li><a class="dropdown-item" href="#"><span class="bi bi-person me-2"></span> Profile</a></li>
                        <li><a class="dropdown-item" href="#"><span class="bi bi-gear me-2"></span> Settings</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="#"><span class="bi bi-box-arrow-right me-2"></span> Logout</a></li>
                    </ul>
                </div>
            </div>
        </header>

        <!-- Dynamic Page Content -->
        <article class="content p-4 flex-grow-1">
            <div class="container-fluid p-0">
                @Body
            </div>
        </article>
        
        <!-- Footer -->
        <footer class="mt-auto px-4 py-3 bg-white border-top text-muted d-flex justify-content-between" style="font-size: 0.85rem;">
            <span>&copy; @DateTime.Now.Year RIVORA Framework</span>
            <span>Version 4.0.0</span>
        </footer>
    </main>
</div>

<div id="blazor-error-ui" class="bg-danger text-white p-3 rounded shadow" data-nosnippet style="display: none; position: fixed; bottom: 20px; right: 20px; z-index: 2000;">
    An unhandled error has occurred.
    <a href="." class="text-white fw-bold ms-2 me-3">Reload</a>
    <a class="dismiss cursor-pointer fw-bold">🗙</a>
</div>
