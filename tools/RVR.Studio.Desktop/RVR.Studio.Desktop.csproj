<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFrameworks>net9.0-windows10.0.19041.0;net9.0-maccatalyst;net9.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <RootNamespace>RVR.Studio.Desktop</RootNamespace>
    <UseMaui>true</UseMaui>
    <SingleProject>true</SingleProject>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- Display settings -->
    <ApplicationTitle>RVR Studio</ApplicationTitle>
    <ApplicationId>com.rivora.studio</ApplicationId>
    <ApplicationIdGuid>3E5A8F2B-7C4D-4E6F-9A1B-2D3E4F5A6B7C</ApplicationIdGuid>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>

    <!-- Windows -->
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">10.0.17763.0</SupportedOSPlatformVersion>
    <TargetPlatformMinVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">10.0.17763.0</TargetPlatformMinVersion>

    <!-- macOS -->
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'maccatalyst'">14.0</SupportedOSPlatformVersion>
  </PropertyGroup>

  <ItemGroup>
    <!-- Shared Blazor components from Admin -->
    <ProjectReference Include="..\..\src\ui\RVR.Framework.Admin\RVR.Framework.Admin.csproj" />
  </ItemGroup>

</Project>
