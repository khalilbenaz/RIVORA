@page "/audit-logs"

<PageTitle>Audit Logs - KBA Studio</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🛡️ Audit Logs Explorer</h2>
    <div class="input-group w-50">
        <input type="text" class="form-control" placeholder="Search by User, Tenant, or Action..." />
        <button class="btn btn-outline-secondary" type="button">Search</button>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center bg-light">
        <strong>Recent System Activity</strong>
        <span class="badge bg-secondary">Total Records: 45,210</span>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Timestamp (UTC)</th>
                    <th>Tenant ID</th>
                    <th>User ID</th>
                    <th>Action / Endpoint</th>
                    <th>Status</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>2026-03-12 14:32:10</td>
                    <td><span class="badge bg-info text-dark">Tenant-A</span></td>
                    <td>user_4492</td>
                    <td><code>POST /api/products</code></td>
                    <td><span class="badge bg-success">201 Created</span></td>
                    <td><button class="btn btn-sm btn-link">View JSON</button></td>
                </tr>
                <tr>
                    <td>2026-03-12 14:28:45</td>
                    <td><span class="badge bg-secondary">Host</span></td>
                    <td>admin_01</td>
                    <td><code>PUT /api/tenants/suspend</code></td>
                    <td><span class="badge bg-success">200 OK</span></td>
                    <td><button class="btn btn-sm btn-link">View JSON</button></td>
                </tr>
                <tr>
                    <td>2026-03-12 14:15:00</td>
                    <td><span class="badge bg-warning text-dark">Tenant-B</span></td>
                    <td>user_8821</td>
                    <td><code>DELETE /api/orders/55</code></td>
                    <td><span class="badge bg-danger">403 Forbidden</span></td>
                    <td><button class="btn btn-sm btn-link text-danger">View Error</button></td>
                </tr>
                <tr>
                    <td>2026-03-12 13:55:22</td>
                    <td><span class="badge bg-info text-dark">Tenant-A</span></td>
                    <td>user_4492</td>
