@page "/entity-builder"
@using System.IO
@rendermode InteractiveServer

<PageTitle>KBA Studio - Entity Builder</PageTitle>

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2>🛠️ Visual Entity Builder (Full-Stack)</h2>
            <p class="text-muted">Générez l'Entité, la Configuration EF Core, les DTOs et le Controller API en un clic.</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(GenerationMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @((MarkupString)GenerationMessage)
            <button type="button" class="btn-close" @onclick="@(() => GenerationMessage = "")"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-primary">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0"><span class="bi bi-magic me-2"></span> AI Schema to Code (Generative UI)</h5>
                    <span class="badge bg-light text-primary">BETA</span>
                </div>
                <div class="card-body bg-light">
                    <div class="input-group">
                        <textarea class="form-control" rows="2" @bind="AiPrompt" placeholder="Décrivez votre besoin... (ex: 'Génère une entité Animal pour une clinique vétérinaire, avec nom, âge, espèce, et l\'id du propriétaire')"></textarea>
                        <button class="btn btn-primary px-4" @onclick="GenerateSchemaFromAi" disabled="@IsGeneratingSchema">
                            @if (IsGeneratingSchema)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> <span class="ms-2">Réflexion...</span>
                            }
                            else
                            {
                                <span>Générer</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Configuration de base -->
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">1. Propriétés de l'Entité</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Nom de l'Entité (ex: Invoice)</label>
                        <input type="text" class="form-control" @bind="EntityName" placeholder="Ex: Customer" />
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="isAggregateRoot" @bind="IsAggregateRoot">
                        <label class="form-check-label" for="isAggregateRoot">C'est une Aggregate Root</label>
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="isMultitenant" @bind="IsMultitenant">
                        <label class="form-check-label" for="isMultitenant">Support Multitenant (IMustHaveTenant)</label>
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="hasAuditLog" @bind="HasAuditLog">
                        <label class="form-check-label" for="hasAuditLog">Tracer les modifications (IAuditableEntity)</label>
                    </div>
                </div>
            </div>

            <!-- Migrations Database -->
            <div class="card shadow-sm mb-4 border-warning">
                <div class="card-header bg-warning text-dark">
                    <h5 class="card-title mb-0">3. Database Migrations</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Nom de la Migration</label>
                        <input type="text" class="form-control" @bind="MigrationName" placeholder="Add_New_Entity" />
                    </div>
                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-warning" @onclick="CreateMigration" disabled="@IsBusy">
                            @(IsBusy ? "⚙️ Exécution..." : "➕ Créer la Migration")
                        </button>
                        <button class="btn btn-warning" @onclick="UpdateDatabase" disabled="@IsBusy">
                            @(IsBusy ? "⚙️ Exécution..." : "🔄 Mettre à jour la DB")
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Attributs -->
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">2. Champs de l'Entité</h5>
                    <button class="btn btn-sm btn-light" @onclick="AddField">+ Ajouter un champ</button>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Nom</th>
                                <th>Type</th>
                                <th>Max Length (String)</th>
                                <th>Requis</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var field in Fields)
                            {
                                <tr>
                                    <td>
                                        <input type="text" class="form-control form-control-sm" @bind="field.Name" />
                                    </td>
                                    <td>
                                        <select class="form-select form-select-sm" @bind="field.Type">
                                            <option value="string">string</option>
                                            <option value="int">int</option>
                                            <option value="decimal">decimal</option>
                                            <option value="bool">bool</option>
                                            <option value="DateTime">DateTime</option>
                                            <option value="Guid">Guid</option>
                                        </select>
                                    </td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm" @bind="field.MaxLength" disabled="@(field.Type != "string")" />
                                    </td>
                                    <td class="text-center">
                                        <input type="checkbox" class="form-check-input" @bind="field.IsRequired" />
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveField(field)">🗑️</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12 text-end">
            <button class="btn btn-outline-secondary btn-lg me-2" @onclick="GenerateCode" disabled="@(string.IsNullOrWhiteSpace(EntityName))">
                🔍 Prévisualiser
            </button>
            <button class="btn btn-success btn-lg" @onclick="SaveFilesToDisk" disabled="@(string.IsNullOrWhiteSpace(EntityName))">
                💾 Générer PHYSIQUEMENT les fichiers
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(GeneratedEntityCode))
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white p-0">
                        <ul class="nav nav-tabs card-header-tabs m-0 ms-2" style="border-bottom: none; margin-top: 8px !important;">
                            <li class="nav-item">
                                <button type="button" class="nav-link border-0 @(ActiveTab == "domain" ? "active bg-light text-dark fw-bold" : "text-light bg-transparent")" @onclick="@(() => ActiveTab = "domain")">Domain Entity</button>
                            </li>
                            <li class="nav-item">
                                <button type="button" class="nav-link border-0 @(ActiveTab == "efcore" ? "active bg-light text-dark fw-bold" : "text-light bg-transparent")" @onclick="@(() => ActiveTab = "efcore")">EF Core Config</button>
                            </li>
                            <li class="nav-item">
                                <button type="button" class="nav-link border-0 @(ActiveTab == "dtos" ? "active bg-light text-dark fw-bold" : "text-light bg-transparent")" @onclick="@(() => ActiveTab = "dtos")">DTOs</button>
                            </li>
                            <li class="nav-item">
                                <button type="button" class="nav-link border-0 @(ActiveTab == "api" ? "active bg-light text-dark fw-bold" : "text-light bg-transparent")" @onclick="@(() => ActiveTab = "api")">API Controller</button>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body bg-light">
                        @if (ActiveTab == "domain") { 
                            <pre><code>@GeneratedEntityCode</code></pre> 
                        }
                        else if (ActiveTab == "efcore") { 
                            <pre><code>@GeneratedEfCoreCode</code></pre> 
                        }
                        else if (ActiveTab == "dtos") { 
                            <pre><code>@GeneratedDtosCode</code></pre> 
                        }
                        else if (ActiveTab == "api") { 
                            <pre><code>@GeneratedApiCode</code></pre> 
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@using OpenAI.Chat
@using Anthropic.SDK
@using Anthropic.SDK.Constants
@using Anthropic.SDK.Messaging
@using System.ClientModel
@using System.Text.Json

@code {
    private string AiPrompt { get; set; } = "";
    private bool IsGeneratingSchema { get; set; } = false;

    private async Task GenerateSchemaFromAi()
    {
        if (string.IsNullOrWhiteSpace(AiPrompt)) return;

        IsGeneratingSchema = true;
        StateHasChanged();

        var openAiKey = Environment.GetEnvironmentVariable("OPENAI_API_KEY");
        var anthropicKey = Environment.GetEnvironmentVariable("ANTHROPIC_API_KEY");
        var ollamaUrl = Environment.GetEnvironmentVariable("OLLAMA_API_URL") ?? "http://localhost:11434/v1";
        var kiloUrl = Environment.GetEnvironmentVariable("KILO_API_URL") ?? "http://localhost:8080/v1";
        var enableLocalAi = Environment.GetEnvironmentVariable("ENABLE_LOCAL_AI"); // "ollama" or "kilo"
        
        var systemPrompt = @"Tu es un générateur de schéma C# pour KBA.Framework. 
L'utilisateur va te décrire une entité. Tu dois retourner UNIQUEMENT du JSON valide représentant cette entité. 
Ne met pas de markdown ```json, renvoie uniquement le texte JSON brut.
Format attendu:
{
  ""Name"": ""NomDeLEntiteSingulierEnAnglais"",
  ""IsAggregateRoot"": true,
  ""IsMultitenant"": true,
  ""HasAuditLog"": true,
  ""Fields"": [
    { ""Name"": ""NomPropriete"", ""Type"": ""string|int|decimal|bool|DateTime|Guid"", ""IsRequired"": true, ""MaxLength"": 100 }
  ]
}";

        try
        {
            string jsonResponse = "";

            if (enableLocalAi == "ollama" || enableLocalAi == "kilo")
            {
                var endpoint = enableLocalAi == "ollama" ? ollamaUrl : kiloUrl;
                var clientOptions = new OpenAIClientOptions { Endpoint = new Uri(endpoint) };
                var model = enableLocalAi == "ollama" ? "llama3" : "kilo-model";
                var client = new ChatClient(model, new ApiKeyCredential("local-dummy-key"), clientOptions);
                var messages = new List<ChatMessage>
                {
                    new SystemChatMessage(systemPrompt),
                    new UserChatMessage(AiPrompt)
                };

                var response = await client.CompleteChatAsync(messages);
                jsonResponse = response.Value.Content[0].Text.Trim();
                GenerationMessage = $"✨ <b>Magie IA !</b> Le schéma a été généré via <b>Local {enableLocalAi.ToUpper()}</b> depuis votre prompt.";
            }
            else if (!string.IsNullOrEmpty(anthropicKey))
            {
                // Utilisation de Claude (Anthropic)
                var client = new AnthropicClient(anthropicKey);
                var parameters = new MessageParameters()
                {
                    Messages = new List<Message>()
                    {
                        new Message()
                        {
                            Role = RoleType.User,
                            Content = new List<ContentBase>() { new TextContent() { Text = AiPrompt } }
                        }
                    },
                    MaxTokens = 2048,
                    Model = AnthropicModels.Claude35Sonnet,
                    System = new List<SystemMessage>() { new SystemMessage(systemPrompt) }
                };

                var response = await client.Messages.GetClaudeMessageAsync(parameters);
                var textContent = response.Message.Content[0] as TextContent;
                jsonResponse = textContent?.Text?.Trim() ?? "";
                GenerationMessage = "✨ <b>Magie IA !</b> Le schéma a été généré via <b>Claude (Anthropic)</b> depuis votre prompt.";
            }
            else if (!string.IsNullOrEmpty(openAiKey))
            {
                // Utilisation d'OpenAI
                var client = new ChatClient("gpt-4o-mini", new ApiKeyCredential(openAiKey));
                var messages = new List<ChatMessage>
                {
                    new SystemChatMessage(systemPrompt),
                    new UserChatMessage(AiPrompt)
                };

                var response = await client.CompleteChatAsync(messages);
                jsonResponse = response.Value.Content[0].Text.Trim();
                GenerationMessage = "✨ <b>Magie IA !</b> Le schéma a été généré via <b>OpenAI</b> depuis votre prompt.";
            }
            else
            {
                // Pas de clé API = On joue la démo locale comme avant
                await Task.Delay(1500);
                RunLocalMock();
                GenerationMessage = "✨ <b>Démo locale !</b> (Pour utiliser la vraie IA, ajoutez OPENAI_API_KEY ou ANTHROPIC_API_KEY dans vos variables d'environnement).";
                IsGeneratingSchema = false;
                StateHasChanged();
                return;
            }
            
            // Nettoyage du JSON si l'IA a mis des balises Markdown
            if (jsonResponse.StartsWith("```json")) {
                jsonResponse = jsonResponse.Replace("```json", "").Replace("```", "").Trim();
            }

            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var generatedSchema = JsonSerializer.Deserialize<GeneratedEntitySchema>(jsonResponse, options);

            if (generatedSchema != null)
            {
                EntityName = generatedSchema.Name;
                IsAggregateRoot = generatedSchema.IsAggregateRoot;
                IsMultitenant = generatedSchema.IsMultitenant;
                HasAuditLog = generatedSchema.HasAuditLog;
                Fields = generatedSchema.Fields ?? new List<EntityField>();
            }
        }
        catch (Exception ex)
        {
            GenerationMessage = $"❌ <b>Erreur IA :</b> {ex.Message} (Assurez-vous que le JSON renvoyé est valide). Fallback sur la démo locale activé.";
            RunLocalMock();
        }

        IsGeneratingSchema = false;
        StateHasChanged();
    }

    private void RunLocalMock()
    {
        var lowerPrompt = AiPrompt.ToLower();
        
        if (lowerPrompt.Contains("animal") || lowerPrompt.Contains("vétérinaire"))
        {
            EntityName = "Animal";
            IsAggregateRoot = true;
            IsMultitenant = true;
            Fields = new List<EntityField>
            {
                new EntityField { Name = "Name", Type = "string", IsRequired = true, MaxLength = 100 },
                new EntityField { Name = "Species", Type = "string", IsRequired = true, MaxLength = 50 },
                new EntityField { Name = "Age", Type = "int", IsRequired = false },
                new EntityField { Name = "OwnerId", Type = "Guid", IsRequired = true }
            };
        }
        else
        {
            EntityName = "Patient";
            IsAggregateRoot = true;
            Fields = new List<EntityField>
            {
                new EntityField { Name = "FirstName", Type = "string", IsRequired = true, MaxLength = 100 },
                new EntityField { Name = "LastName", Type = "string", IsRequired = true, MaxLength = 100 },
                new EntityField { Name = "DateOfBirth", Type = "DateTime", IsRequired = true },
                new EntityField { Name = "BloodType", Type = "string", IsRequired = false, MaxLength = 5 }
            };
        }
    }

    private class GeneratedEntitySchema
    {
        public string Name { get; set; } = "";
        public bool IsAggregateRoot { get; set; }
        public bool IsMultitenant { get; set; }
        public bool HasAuditLog { get; set; }
        public List<EntityField>? Fields { get; set; }
    }

    private string EntityName { get; set; } = "Invoice";
    private bool IsAggregateRoot { get; set; } = true;
    private bool IsMultitenant { get; set; } = true;
    private bool HasAuditLog { get; set; } = true;
    
    private string MigrationName { get; set; } = "";
    private bool IsBusy { get; set; } = false;
    
    private string ActiveTab { get; set; } = "domain";
    private string GenerationMessage { get; set; } = "";
    
    private List<EntityField> Fields { get; set; } = new()
    {
        new EntityField { Name = "Reference", Type = "string", IsRequired = true, MaxLength = 50 },
        new EntityField { Name = "Amount", Type = "decimal", IsRequired = true },
        new EntityField { Name = "IssueDate", Type = "DateTime", IsRequired = true }
    };
    
    private string GeneratedEntityCode { get; set; } = "";
    private string GeneratedEfCoreCode { get; set; } = "";
    private string GeneratedDtosCode { get; set; } = "";
    private string GeneratedApiCode { get; set; } = "";

    private void AddField() => Fields.Add(new EntityField { Name = "NewField", Type = "string", IsRequired = false, MaxLength = 255 });
    private void RemoveField(EntityField field) => Fields.Remove(field);

    private void GenerateCode()
    {
        GenerateDomainCode();
        GenerateEfCoreCode();
        GenerateDtosCode();
        GenerateApiCode();
    }

    private void GenerateDomainCode()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("using KBA.Framework.Domain.Entities;");
        sb.AppendLine("using System;");
        sb.AppendLine();
        sb.AppendLine("namespace KBA.Framework.Domain.Entities;");
        sb.AppendLine();
        
        var baseClass = IsAggregateRoot ? "AggregateRoot<Guid>" : "Entity<Guid>";
        var interfaces = new List<string>();
        if (IsMultitenant) interfaces.Add("IMustHaveTenant");
        if (HasAuditLog) interfaces.Add("IAuditableEntity");

        var inheritance = baseClass + (interfaces.Any() ? ", " + string.Join(", ", interfaces) : "");

        sb.AppendLine($"public class {EntityName} : {inheritance}");
        sb.AppendLine("{");

        foreach (var field in Fields)
        {
            var nullable = field.IsRequired || field.Type == "string" ? "" : "?";
            if (field.Type == "string" && !field.IsRequired) nullable = "?";
            sb.AppendLine($"    public {field.Type}{nullable} {field.Name} {{ get; private set; }}");
        }
        
        if (IsMultitenant)
        {
            sb.AppendLine();
            sb.AppendLine("    public string TenantId { get; set; }");
        }

        sb.AppendLine();
        sb.AppendLine($"    protected {EntityName}() {{ }} // Pour EF Core");
        sb.AppendLine();
        
        var constructorParams = string.Join(", ", Fields.Where(f => f.IsRequired).Select(f => $"{f.Type} {f.Name.ToLower()}"));
        sb.AppendLine($"    public {EntityName}({constructorParams})");
        sb.AppendLine("    {");
        foreach(var field in Fields.Where(f => f.IsRequired))
        {
            sb.AppendLine($"        {field.Name} = {field.Name.ToLower()};");
        }
        sb.AppendLine("    }");
        
        sb.AppendLine("    ");
        sb.AppendLine($"    public void Update({constructorParams})");
        sb.AppendLine("    {");
        foreach(var field in Fields.Where(f => f.IsRequired))
        {
            sb.AppendLine($"        {field.Name} = {field.Name.ToLower()};");
        }
        sb.AppendLine("    }");

        sb.AppendLine("}");
        GeneratedEntityCode = sb.ToString();
    }

    private void GenerateEfCoreCode()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("using Microsoft.EntityFrameworkCore;");
        sb.AppendLine("using Microsoft.EntityFrameworkCore.Metadata.Builders;");
        sb.AppendLine("using KBA.Framework.Domain.Entities;");
        sb.AppendLine();
        sb.AppendLine("namespace KBA.Framework.Infrastructure.Data.Configurations;");
        sb.AppendLine();
        sb.AppendLine($"public class {EntityName}Configuration : IEntityTypeConfiguration<{EntityName}>");
        sb.AppendLine("{");
        sb.AppendLine($"    public void Configure(EntityTypeBuilder<{EntityName}> builder)");
        sb.AppendLine("    {");
        sb.AppendLine($"        builder.ToTable(\"{EntityName}s\");");
        sb.AppendLine($"        builder.HasKey(x => x.Id);");
        sb.AppendLine();
        foreach (var field in Fields)
        {
            sb.Append($"        builder.Property(x => x.{field.Name})");
            if (field.IsRequired) sb.Append(".IsRequired()");
            if (field.Type == "string" && field.MaxLength > 0) sb.Append($".HasMaxLength({field.MaxLength})");
            if (field.Type == "decimal") sb.Append(".HasColumnType(\"decimal(18,2)\")");
            sb.AppendLine(";");
        }
        
        if (IsMultitenant)
        {
            sb.AppendLine();
            sb.AppendLine($"        // Filtre Multitenant global");
            sb.AppendLine($"        builder.HasQueryFilter(x => EF.Property<string>(x, \"TenantId\") == _tenantService.GetCurrentTenantId());");
        }

        sb.AppendLine("    }");
        sb.AppendLine("}");
        GeneratedEfCoreCode = sb.ToString();
    }

    private void GenerateDtosCode()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("using System;");
        sb.AppendLine("using System.ComponentModel.DataAnnotations;");
        sb.AppendLine();
        sb.AppendLine($"namespace KBA.Framework.Application.DTOs.{Pluralize(EntityName)};");
        sb.AppendLine();
        
        // Response DTO
        sb.AppendLine($"public class {EntityName}Dto");
        sb.AppendLine("{");
        sb.AppendLine("    public Guid Id { get; set; }");
        foreach (var field in Fields) sb.AppendLine($"    public {field.Type} {field.Name} {{ get; set; }}");
        sb.AppendLine("}");
        sb.AppendLine();
        
        // Create DTO
        sb.AppendLine($"public class Create{EntityName}Dto");
        sb.AppendLine("{");
        foreach (var field in Fields)
        {
            if (field.IsRequired) sb.AppendLine("    [Required]");
            if (field.Type == "string" && field.MaxLength > 0) sb.AppendLine($"    [MaxLength({field.MaxLength})]");
            sb.AppendLine($"    public {field.Type} {field.Name} {{ get; set; }}");
        }
        sb.AppendLine("}");
        sb.AppendLine();

        // Update DTO
        sb.AppendLine($"public class Update{EntityName}Dto");
        sb.AppendLine("{");
        foreach (var field in Fields)
        {
            if (field.IsRequired) sb.AppendLine("    [Required]");
            if (field.Type == "string" && field.MaxLength > 0) sb.AppendLine($"    [MaxLength({field.MaxLength})]");
            sb.AppendLine($"    public {field.Type} {field.Name} {{ get; set; }}");
        }
        sb.AppendLine("}");

        GeneratedDtosCode = sb.ToString();
    }

    private void GenerateApiCode()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("using Microsoft.AspNetCore.Mvc;");
        sb.AppendLine($"using KBA.Framework.Application.DTOs.{Pluralize(EntityName)};");
        sb.AppendLine("using System;");
        sb.AppendLine("using System.Threading.Tasks;");
        sb.AppendLine();
        sb.AppendLine("namespace KBA.Framework.Api.Controllers;");
        sb.AppendLine();
        sb.AppendLine("[ApiController]");
        sb.AppendLine($"[Route(\"api/[controller]\")]");
        sb.AppendLine($"public class {Pluralize(EntityName)}Controller : ControllerBase");
        sb.AppendLine("{");
        sb.AppendLine($"    private readonly I{EntityName}Service _service;");
        sb.AppendLine();
        sb.AppendLine($"    public {Pluralize(EntityName)}Controller(I{EntityName}Service service)");
        sb.AppendLine("    {");
        sb.AppendLine("        _service = service;");
        sb.AppendLine("    }");
        sb.AppendLine();
        sb.AppendLine("    [HttpGet]");
        sb.AppendLine($"    public async Task<IActionResult> GetAll()");
        sb.AppendLine("    {");
        sb.AppendLine($"        return Ok(await _service.GetAllAsync());");
        sb.AppendLine("    }");
        sb.AppendLine();
        sb.AppendLine("    [HttpGet(\"{id}\")]");
        sb.AppendLine($"    public async Task<IActionResult> GetById(Guid id)");
        sb.AppendLine("    {");
        sb.AppendLine($"        return Ok(await _service.GetByIdAsync(id));");
        sb.AppendLine("    }");
        sb.AppendLine();
        sb.AppendLine("    [HttpPost]");
        sb.AppendLine($"    public async Task<IActionResult> Create(Create{EntityName}Dto dto)");
        sb.AppendLine("    {");
        sb.AppendLine($"        var id = await _service.CreateAsync(dto);");
        sb.AppendLine($"        return CreatedAtAction(nameof(GetById), new {{ id }}, dto);");
        sb.AppendLine("    }");
        sb.AppendLine();
        sb.AppendLine("    [HttpPut(\"{id}\")]");
        sb.AppendLine($"    public async Task<IActionResult> Update(Guid id, Update{EntityName}Dto dto)");
        sb.AppendLine("    {");
        sb.AppendLine($"        await _service.UpdateAsync(id, dto);");
        sb.AppendLine($"        return NoContent();");
        sb.AppendLine("    }");
        sb.AppendLine();
        sb.AppendLine("    [HttpDelete(\"{id}\")]");
        sb.AppendLine($"    public async Task<IActionResult> Delete(Guid id)");
        sb.AppendLine("    {");
        sb.AppendLine($"        await _service.DeleteAsync(id);");
        sb.AppendLine($"        return NoContent();");
        sb.AppendLine("    }");
        sb.AppendLine("}");
        
        GeneratedApiCode = sb.ToString();
    }

    private async Task SaveFilesToDisk()
    {
        try
        {
            GenerateCode();
            
            // On remonte au dossier racine de la solution (depuis tools/KBA.Studio/bin/...)
            // Ou on utilise un chemin relatif par rapport au projet en développement.
            // Pour être sûr, on va utiliser le chemin que l'utilisateur a indiqué.
            var basePath = Path.GetFullPath(Path.Combine(AppContext.BaseDirectory, "../../../../"));
            
            // Si on tourne en dev mode avec dotnet run, le BaseDirectory peut varier.
            // On peut aussi essayer de localiser le dossier "src" en remontant.
            var currentDir = AppContext.BaseDirectory;
            while (!string.IsNullOrEmpty(currentDir) && !Directory.Exists(Path.Combine(currentDir, "src")))
            {
                currentDir = Path.GetDirectoryName(currentDir);
            }
            
            if (string.IsNullOrEmpty(currentDir))
            {
                GenerationMessage = "❌ Impossible de localiser le dossier 'src' de la solution.";
                return;
            }

            basePath = currentDir;
            var pluralEntity = Pluralize(EntityName);
            
            // 1. Domain
            var domainPath = Path.Combine(basePath, "src", "KBA.Framework.Domain", "Entities", pluralEntity);
            Directory.CreateDirectory(domainPath);
            await File.WriteAllTextAsync(Path.Combine(domainPath, $"{EntityName}.cs"), GeneratedEntityCode);
            
            // 2. Infrastructure (EF Core Config)
            var infraPath = Path.Combine(basePath, "src", "KBA.Framework.Infrastructure", "Data", "Configurations");
            Directory.CreateDirectory(infraPath);
            await File.WriteAllTextAsync(Path.Combine(infraPath, $"{EntityName}Configuration.cs"), GeneratedEfCoreCode);
            
            // 3. Application (DTOs)
            var appPath = Path.Combine(basePath, "src", "KBA.Framework.Application", "DTOs", pluralEntity);
            Directory.CreateDirectory(appPath);
            await File.WriteAllTextAsync(Path.Combine(appPath, $"{EntityName}Dtos.cs"), GeneratedDtosCode);
            
            // 4. API (Controller)
            var apiPath = Path.Combine(basePath, "src", "KBA.Framework.Api", "Controllers");
            Directory.CreateDirectory(apiPath);
            await File.WriteAllTextAsync(Path.Combine(apiPath, $"{pluralEntity}Controller.cs"), GeneratedApiCode);
            
            GenerationMessage = $"✅ <b>Succès !</b> Les fichiers pour l'entité <b>{EntityName}</b> ont été générés dans :<br/>" +
                               $"- {domainPath}<br/>" +
                               $"- {infraPath}<br/>" +
                               $"- {appPath}<br/>" +
                               $"- {apiPath}";
        }
        catch (Exception ex)
        {
            GenerationMessage = $"❌ <b>Erreur :</b> {ex.Message}";
        }
    }

    private async Task CreateMigration()
    {
        if (string.IsNullOrWhiteSpace(MigrationName))
        {
            GenerationMessage = "⚠️ Veuillez saisir un nom pour la migration.";
            return;
        }

        var projectName = "src/KBA.Framework.Infrastructure";
        var startupProject = "src/KBA.Framework.Api";
        var cmd = $"dotnet ef migrations add {MigrationName} --project {projectName} --startup-project {startupProject}";
        
        await RunCommandAsync(cmd, "Création de la migration");
    }

    private async Task UpdateDatabase()
    {
        var projectName = "src/KBA.Framework.Infrastructure";
        var startupProject = "src/KBA.Framework.Api";
        var cmd = $"dotnet ef database update --project {projectName} --startup-project {startupProject}";
        
        await RunCommandAsync(cmd, "Mise à jour de la base de données");
    }

    private async Task RunCommandAsync(string command, string taskName)
    {
        IsBusy = true;
        GenerationMessage = $"⚙️ <b>{taskName}...</b> en cours d'exécution.";
        StateHasChanged();

        try
        {
            var basePath = GetSolutionRoot();
            if (string.IsNullOrEmpty(basePath)) return;

            var process = new System.Diagnostics.Process
            {
                StartInfo = new System.Diagnostics.ProcessStartInfo
                {
                    FileName = "cmd.exe",
                    Arguments = $"/c {command}",
                    WorkingDirectory = basePath,
                    RedirectStandardOutput = true,
                    RedirectStandardError = true,
                    UseShellExecute = false,
                    CreateNoWindow = true
                }
            };

            process.Start();
            var output = await process.StandardOutput.ReadToEndAsync();
            var error = await process.StandardError.ReadToEndAsync();
            await process.WaitForExitAsync();

            if (process.ExitCode == 0)
            {
                GenerationMessage = $"✅ <b>{taskName} réussie !</b><br/><pre style='font-size: 0.8em; max-height: 200px; overflow: auto;'>{output}</pre>";
            }
            else
            {
                GenerationMessage = $"❌ <b>{taskName} a échoué :</b><br/><pre style='color: red; font-size: 0.8em; max-height: 200px; overflow: auto;'>{error}{output}</pre>";
            }
        }
        catch (Exception ex)
        {
            GenerationMessage = $"❌ <b>Erreur système :</b> {ex.Message}";
        }
        finally
        {
            IsBusy = false;
            StateHasChanged();
        }
    }

    private string GetSolutionRoot()
    {
        var currentDir = AppContext.BaseDirectory;
        while (!string.IsNullOrEmpty(currentDir) && !Directory.Exists(Path.Combine(currentDir, "src")))
        {
            currentDir = Path.GetDirectoryName(currentDir);
        }
        
        if (string.IsNullOrEmpty(currentDir))
        {
            GenerationMessage = "❌ Impossible de localiser le dossier 'src' de la solution.";
            return "";
        }
        return currentDir;
    }

    private string Pluralize(string name)
    {
        if (name.EndsWith("y")) return name.Substring(0, name.Length - 1) + "ies";
        if (name.EndsWith("s")) return name;
        return name + "s";
    }

    public class EntityField
    {
        public string Name { get; set; } = "";
        public string Type { get; set; } = "string";
        public bool IsRequired { get; set; } = true;
        public int? MaxLength { get; set; }
    }
