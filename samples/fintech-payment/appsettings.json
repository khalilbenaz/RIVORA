{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=fintech-payment.db"
  },
  "Webhooks": {
    "MaxRetries": 3,
    "RetryDelaySeconds": 10,
    "TimeoutSeconds": 30
  },
  "Billing": {
    "StripeApiKey": "sk_test_demo_key",
    "StripeWebhookSecret": "whsec_demo_secret",
    "DefaultCurrency": "eur",
    "TransactionFeePercent": 2.9,
    "FixedFeeAmount": 0.30
  },
  "Idempotency": {
    "TTLMinutes": 1440,
    "HeaderName": "X-Idempotency-Key"
  },
  "Kestrel": {
    "Endpoints": {
      "Https": {
        "Url": "https://localhost:5001"
      }
    }
  }
}
