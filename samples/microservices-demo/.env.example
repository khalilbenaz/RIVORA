# Microservices Demo - Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit the .env file to version control.

# PostgreSQL (shared across identity, products, and orders databases)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=change_me_rabbitmq

# JWT signing key (must be at least 32 characters)
JWT_SECRET_KEY=ReplaceWithASecureRandomStringAtLeast32Chars!
