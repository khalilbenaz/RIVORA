# SaaS Starter Sample - Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit the .env file to version control.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres

# Identity / JWT signing key (must be at least 32 characters)
IDENTITY_SECRET_KEY=ReplaceWithASecureRandomStringAtLeast32Chars!
